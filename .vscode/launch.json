{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Go server",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend/cmd/server",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Debug Vue app",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend/flow-control-ui/src",
      "preLaunchTask": "debug: frontend server"
    }
  ],
  "compounds": [
    {
      "name": "Debug full stack",
      "configurations": [
        "Debug Go server",
        "Debug Vue app"
      ],
      "stopAll": true
    }
  ]
}
