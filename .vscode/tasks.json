{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: backend",
      "type": "shell",
      "command": "go run ./cmd/server",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": {
        "base": "$go",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "^.*Go server listening on http://localhost.*$"
        }
      },
      "presentation": {
        "group": "development",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "dev: frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend/flow-control-ui"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^(?!)$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*VITE.*$",
          "endsPattern": "^.*Local:.*http://localhost:5173/.*$"
        }
      },
      "presentation": {
        "group": "development",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "debug: frontend server",
      "type": "shell",
      "command": "npm run dev:debug",
      "options": {
        "cwd": "${workspaceFolder}/frontend/flow-control-ui"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^(?!)$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*VITE.*$",
          "endsPattern": "^.*Local:.*http://localhost:5173/.*$"
        }
      },
      "presentation": {
        "group": "development",
        "panel": "dedicated",
        "reveal": "silent"
      }
    },
    {
      "label": "dev",
      "dependsOrder": "parallel",
      "dependsOn": [
        "dev: backend",
        "dev: frontend"
      ],
      "problemMatcher": []
    }
  ]
}
